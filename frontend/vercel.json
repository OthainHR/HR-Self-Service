{
  "framework": "create-react-app",
  "buildCommand": "npm run build",
  "outputDirectory": "build",
  "env": {
    "REACT_APP_SUPABASE_URL": "",
    "REACT_APP_SUPABASE_ANON_KEY": "",
    "REACT_APP_API_URL": ""
  },
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://hr-self-service.onrender.com/api/:path*"
    }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": []
    }
  ]
} 